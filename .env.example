# ===================================================================
# CreditTracker Environment Variables
# ===================================================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.
# ===================================================================

# ----- Supabase -----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----- Application -----
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:4200

# ----- Auth -----
# JWT secret used for signing tokens (generate a strong random value)
JWT_SECRET=replace-with-a-strong-random-secret

# ----- Database (if using direct connection) -----
DATABASE_URL=postgresql://user:password@localhost:5432/credittracker

# ----- Admin (NEVER hardcode admin credentials in source code) -----
# Admin credentials should be provisioned via Supabase Auth or a secure vault.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=set-via-secure-vault
